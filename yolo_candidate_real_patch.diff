+    def move_action_candidates(self) -> list[CandidateAction]:
+        """Return merged move/action candidates for the current selected unit.
+
+        This is a side-channel for candidate-policy experiments.  It does not
+        alter the legacy flat MaskablePPO action space.  Non-MOVE stages return
+        an empty list.
+        """
+        if self.state is None:
+            return []
+        return generate_move_candidates(self.state)
+
+    def move_action_candidate_arrays(
+        self, *, max_candidates: int = 4096
+    ) -> tuple[np.ndarray, np.ndarray]:
+        """Return padded candidate feature rows + bool mask for PPO batching."""
+        if self.state is None:
+            return (
+                np.zeros((max_candidates, 24), dtype=np.float32),
+                np.zeros((max_candidates,), dtype=bool),
+            )
+        return candidates_to_arrays(
+            self.state,
+            generate_move_candidates(self.state),
+            max_candidates=max_candidates,
+        )
+
+    def step_move_action_candidate(self, candidate_idx: int) -> None:
+        """Execute one generated MOVE-stage candidate through the staged engine.
+
+        This helper intentionally does not perform reward/accounting/opponent
+        autoplay.  It is for tests and for a future candidate-mode ``step``
+        wrapper; standard training should continue to call ``step(flat_idx)``.
+        """
+        if self.state is None:
+            raise RuntimeError("Call reset() before step_move_action_candidate().")
+        candidates = generate_move_candidates(self.state)
+        idx = int(candidate_idx)
+        if idx < 0 or idx >= len(candidates):
+            raise IndexError(f"candidate_idx {idx} out of range for {len(candidates)} candidates")
+        execute_candidate(self.state, candidates[idx])
+        self._legal_cache = None
+
     def action_masks(self) -> np.ndarray:
         """Return valid-action bool mask. Required by MaskablePPO wrappers."""
         if self.state is None:
