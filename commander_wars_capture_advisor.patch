diff --git a/tests/test_commander_wars_capture_advisor.py b/tests/test_commander_wars_capture_advisor.py
new file mode 100644
index 0000000..6ab88cc
--- /dev/null
+++ b/tests/test_commander_wars_capture_advisor.py
@@ -0,0 +1,98 @@
+"""Smoke tests for the Commander Wars-style capture advisor.
+
+These tests intentionally avoid asserting exact map fixtures.  They pin the
+contract: deterministic, returns a subset of reachable capturable destinations,
+and never suggests owned / non-property tiles.
+"""
+
+from __future__ import annotations
+
+import pytest
+
+from engine.action import compute_reachable_costs
+from engine.commander_wars_capture import advisor_capture_destinations, ranked_capture_destinations
+from engine.unit import UNIT_STATS
+from rl.env import AWBWEnv
+
+
+def _find_foot_unit_with_capture_choices(env: AWBWEnv, max_steps: int = 200):
+    state = env.state
+    for _ in range(max_steps):
+        player = state.active_player
+        for unit in state.units[player]:
+            if not getattr(unit, "is_alive", True):
+                continue
+            if not UNIT_STATS[unit.unit_type].can_capture:
+                continue
+            reachable = set(compute_reachable_costs(state, unit).keys())
+            ranked = ranked_capture_destinations(state, player, unit, reachable)
+            if ranked:
+                return state, player, unit, reachable, ranked
+        legal = env.legal_actions()
+        if not legal:
+            break
+        env.step(env.action_to_index(legal[0]))
+        state = env.state
+    pytest.skip("No early capturable foot-unit state found in sampled env.")
+
+
+def test_commander_capture_advisor_is_subset_and_deterministic():
+    env = AWBWEnv()
+    env.reset(seed=0)
+    state, player, unit, reachable, ranked = _find_foot_unit_with_capture_choices(env)
+
+    a = advisor_capture_destinations(state, player, unit, reachable, top_k=1)
+    b = advisor_capture_destinations(state, player, unit, reachable, top_k=1)
+
+    assert a == b
+    assert a
+    assert a.issubset({x.pos for x in ranked})
+
+
+def test_commander_capture_top_k_keeps_more_or_equal():
+    env = AWBWEnv()
+    env.reset(seed=1)
+    state, player, unit, reachable, _ranked = _find_foot_unit_with_capture_choices(env)
+
+    one = advisor_capture_destinations(state, player, unit, reachable, top_k=1)
+    three = advisor_capture_destinations(state, player, unit, reachable, top_k=3)
+
+    assert one.issubset(three)
+