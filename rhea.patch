+    parser.add_argument("--checkpoint", type=str, required=True)
+    parser.add_argument("--map-id", type=int, default=171596)
+    parser.add_argument("--co-p0", type=int, default=14)
+    parser.add_argument("--co-p1", type=int, default=14)
